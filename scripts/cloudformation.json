{
  "AWSTemplateFormatVersion": "2010-09-09",
  "Description": "Template to create S3 buckets and DynamoDB table for Terraform state locking.",

  "Resources": {
    "TFStateBucket": {
      "Type": "AWS::S3::Bucket",
      "Properties": {
        "BucketName": {
          "Fn::Sub": "tf-state-${AWS::AccountId}-${AWS::Region}"
        }
      }
    },
    "TFLockDBTable": {
      "Type": "AWS::DynamoDB::Table",
      "Properties": {
        "TableName": "tf.lock",
        "BillingMode": "PAY_PER_REQUEST",
        "AttributeDefinitions": [
          {
            "AttributeName": "LockID",
            "AttributeType": "S"
          }
        ],
        "KeySchema": [
          {
            "AttributeName": "LockID",
            "KeyType": "HASH"
          }
        ]
      }
    }
  }
}